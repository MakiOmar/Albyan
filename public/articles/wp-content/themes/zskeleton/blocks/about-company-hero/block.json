{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "zskeleton/about-company-hero",
	"version": "1.0.0",
	"title": "About Company Hero",
	"category": "widgets",
	"icon": "format-image",
	"description": "Hero section with background image, profile picture, title, optional separator, description, and two CTA buttons.",
	"keywords": [ "about", "company", "hero", "cta", "zskeleton" ],
	"textdomain": "zskeleton",
	"editorScript": "zskeleton-about-company-hero-block-editor",
	"style": "file:../../assets/css/about-company-hero-block.css",
	"editorStyle": "file:../../assets/css/about-company-hero-block.css",
	"render": "file:./render.php",
	"attributes": {
		"title": { "type": "string", "default": "About Company" },
		"description": { "type": "string", "default": "" },
		"backgroundImageId": { "type": "number", "default": 0 },
		"backgroundImageUrl": { "type": "string", "default": "" },
		"backgroundImageAlt": { "type": "string", "default": "" },
		"backgroundSize": { "type": "string", "default": "cover" },
		"backgroundPosition": { "type": "string", "default": "center center" },
		"profileImageId": { "type": "number", "default": 0 },
		"profileImageUrl": { "type": "string", "default": "" },
		"profileImageAlt": { "type": "string", "default": "" },
		"profileBorderColor": { "type": "string", "default": "" },
		"titleShowSeparator": { "type": "boolean", "default": true },
		"titleSeparatorWidthPx": { "type": "number", "default": 120 },
		"titleSeparatorHeightPx": { "type": "number", "default": 4 },
		"titleSeparatorRadiusPx": { "type": "number", "default": 999 },
		"titleSeparatorColor": { "type": "string", "default": "" },
		"titleColor": { "type": "string", "default": "" },
		"descriptionColor": { "type": "string", "default": "" },
		"sectionBackgroundColor": { "type": "string", "default": "" },
		"sectionOverlayColor": { "type": "string", "default": "rgba(255,255,255,0.18)" },
		"buttonOneLabel": { "type": "string", "default": "Book a Call" },
		"buttonOneUrl": { "type": "string", "default": "" },
		"buttonOneTarget": { "type": "string", "default": "_self" },
		"buttonTwoLabel": { "type": "string", "default": "Our Works" },
		"buttonTwoUrl": { "type": "string", "default": "" },
		"buttonTwoTarget": { "type": "string", "default": "_self" },
		"buttonOneTextColor": { "type": "string", "default": "" },
		"buttonOneBackgroundColor": { "type": "string", "default": "" },
		"buttonOneBorderColor": { "type": "string", "default": "" },
		"buttonTwoTextColor": { "type": "string", "default": "" },
		"buttonTwoBackgroundColor": { "type": "string", "default": "" },
		"buttonTwoBorderColor": { "type": "string", "default": "" }
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"anchor": true
	}
}
