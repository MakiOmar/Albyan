{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "zskeleton/case-studies-split",
	"version": "1.0.0",
	"title": "Section: Case study split testimonial",
	"category": "widgets",
	"icon": "columns",
	"description": "Section heading with gradient background, tall split row: portrait image column plus content column with blurred photo, logo, text, signature, and role. Heights for desktop and mobile.",
	"keywords": [
		"case studies",
		"testimonial",
		"split",
		"gradient",
		"portfolio",
		"zskeleton"
	],
	"textdomain": "zskeleton",
	"editorScript": "zskeleton-case-studies-split-editor",
	"style": "file:../../assets/css/case-studies-split.css",
	"editorStyle": "file:../../assets/css/case-studies-split.css",
	"attributes": {
		"sectionTitle": { "type": "string", "default": "" },
		"sectionDescription": { "type": "string", "default": "" },
		"stageMinHeightDesktop": { "type": "number", "default": 460 },
		"stageMinHeightMobile": { "type": "number", "default": 480 },
		"portraitMaxHeightDesktop": { "type": "number", "default": 460 },
		"portraitMaxHeightMobile": { "type": "number", "default": 260 },
		"gradientColor1": { "type": "string", "default": "#f8fafc" },
		"gradientColor2": { "type": "string", "default": "#e2e8f0" },
		"gradientAngleDeg": { "type": "number", "default": 160 },
		"leftImageId": { "type": "number", "default": 0 },
		"leftImageUrl": { "type": "string", "default": "" },
		"leftImageAlt": { "type": "string", "default": "" },
		"rightBlurImageId": { "type": "number", "default": 0 },
		"rightBlurImageUrl": { "type": "string", "default": "" },
		"rightBlurImageAlt": { "type": "string", "default": "" },
		"blurRadiusPx": { "type": "number", "default": 18 },
		"brandLogoId": { "type": "number", "default": 0 },
		"brandLogoUrl": { "type": "string", "default": "" },
		"brandLogoAlt": { "type": "string", "default": "" },
		"cardSubtitle": { "type": "string", "default": "" },
		"quoteHtml": { "type": "string", "default": "" },
		"personName": { "type": "string", "default": "" },
		"personRole": { "type": "string", "default": "" },
		"colorSectionTitle": { "type": "string", "default": "" },
		"colorSectionDesc": { "type": "string", "default": "" },
		"colorCardSubtitle": { "type": "string", "default": "" },
		"colorQuote": { "type": "string", "default": "" },
		"colorPersonName": { "type": "string", "default": "" },
		"colorPersonRole": { "type": "string", "default": "" },
		"colorRightPanelTint": { "type": "string", "default": "#ffffff" },
		"borderRadiusPx": { "type": "number", "default": 20 },
		"textDirection": { "type": "string", "default": "auto" },
		"titleDashicon": { "type": "string", "default": "" },
		"titleShowSeparator": { "type": "boolean", "default": true },
		"titleSeparatorWidthPx": { "type": "number", "default": 72 },
		"titleSeparatorHeightPx": { "type": "number", "default": 4 },
		"titleSeparatorRadiusPx": { "type": "number", "default": 999 },
		"titleSeparatorColor": { "type": "string", "default": "#b8d4eb" }
	},
	"supports": {
		"html": false,
		"align": ["wide", "full"]
	},
	"render": "file:./render.php"
}
