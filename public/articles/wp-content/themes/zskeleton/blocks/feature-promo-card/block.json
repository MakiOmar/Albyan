{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "zskeleton/feature-promo-card",
	"version": "1.0.0",
	"title": "Feature promo card",
	"category": "widgets",
	"icon": "index-card",
	"description": "Icon header, title, rich text, bullet list, and pill CTA with customizable fonts and colors.",
	"keywords": [ "card", "cta", "promo", "feature", "zskeleton", "arabic", "rtl" ],
	"textdomain": "zskeleton",
	"editorScript": "zskeleton-feature-promo-card-block-editor",
	"style": "file:../../assets/css/feature-promo-card.css",
	"editorStyle": "file:../../assets/css/feature-promo-card.css",
	"attributes": {
		"title": { "type": "string", "default": "" },
		"bodyHtml": { "type": "string", "default": "" },
		"listItems": {
			"type": "array",
			"default": [ "", "" ]
		},
		"buttonLabel": { "type": "string", "default": "" },
		"buttonUrl": { "type": "string", "default": "" },
		"buttonTarget": { "type": "string", "default": "_self" },
		"buttonRelNoFollow": { "type": "boolean", "default": false },
		"buttonRelSponsored": { "type": "boolean", "default": false },
		"buttonAriaLabel": { "type": "string", "default": "" },
		"iconMode": { "type": "string", "default": "dashicon" },
		"iconImageId": { "type": "number", "default": 0 },
		"iconImageUrl": { "type": "string", "default": "" },
		"iconImageAlt": { "type": "string", "default": "" },
		"iconDashicon": { "type": "string", "default": "groups" },
		"cardBackground": { "type": "string", "default": "#ffffff" },
		"headerBackground": { "type": "string", "default": "#f0f4f7" },
		"titleColor": { "type": "string", "default": "#1e293b" },
		"bodyColor": { "type": "string", "default": "#475569" },
		"listColor": { "type": "string", "default": "#475569" },
		"listBulletColor": { "type": "string", "default": "#64748b" },
		"iconColor": { "type": "string", "default": "#334e68" },
		"buttonBackground": { "type": "string", "default": "#5086b3" },
		"buttonTextColor": { "type": "string", "default": "#ffffff" },
		"titleFontFamily": { "type": "string", "default": "" },
		"bodyFontFamily": { "type": "string", "default": "" },
		"cardBorderRadiusPx": { "type": "number", "default": 24 },
		"cardPaddingPx": { "type": "number", "default": 32 },
		"headerPaddingTopPx": { "type": "number", "default": 28 },
		"headerWaveDepthPx": { "type": "number", "default": 26 },
		"shadowStrength": { "type": "string", "default": "medium" },
		"titleDashicon": { "type": "string", "default": "" },
		"titleShowSeparator": { "type": "boolean", "default": true },
		"titleSeparatorWidthPx": { "type": "number", "default": 72 },
		"titleSeparatorHeightPx": { "type": "number", "default": 4 },
		"titleSeparatorRadiusPx": { "type": "number", "default": 999 },
		"titleSeparatorColor": { "type": "string", "default": "#b8d4eb" }
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	},
	"render": "file:./render.php"
}
