{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "zskeleton/blog-featured",
	"version": "1.0.0",
	"title": "Blog: Featured posts",
	"category": "zskeleton-blog",
	"icon": "star-filled",
	"description": "Featured strip: posts marked “Show in blog Featured strip”, then sticky posts only—no auto newest fill (count from ZSkeleton Content). First page only.",
	"keywords": [ "blog", "featured", "posts", "zskeleton", "ZSkeleton" ],
	"textdomain": "zskeleton",
	"editorScript": "zskeleton-blog-hub-blocks-editor",
	"attributes": {
		"useThemeCount": {
			"type": "boolean",
			"default": true
		},
		"postCount": {
			"type": "number",
			"default": 3
		},
		"sectionHeading": {
			"type": "string",
			"default": ""
		},
		"useThemeVisibility": {
			"type": "boolean",
			"default": true
		},
		"showHeading": { "type": "boolean", "default": true },
		"titleDashicon": { "type": "string", "default": "" },
		"titleShowSeparator": { "type": "boolean", "default": true },
		"titleSeparatorWidthPx": { "type": "number", "default": 72 },
		"titleSeparatorHeightPx": { "type": "number", "default": 4 },
		"titleSeparatorRadiusPx": { "type": "number", "default": 999 },
		"titleSeparatorColor": { "type": "string", "default": "#b8d4eb" },
		"titleListingGapPx": { "type": "number", "default": 20 }
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"visibility": false
	},
	"render": "file:./render.php"
}
