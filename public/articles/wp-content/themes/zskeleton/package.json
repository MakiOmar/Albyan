{
  "name": "zskeleton-theme",
  "version": "1.0.0",
  "description": "ZSkeleton WordPress Theme with minification support",
  "main": "index.js",
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:css": "npm run build:css:main && npm run build:css:components && npm run build:css:admin && npm run build:css:admin-meta-fields && npm run build:css:admin-settings && npm run build:css:faq-admin && npm run build:css:demo-content && npm run build:css:membership-plans && npm run build:css:membership-plans-pricing && npm run build:css:form-kit && npm run build:css:page-contact && npm run build:css:page-title-bar && npm run build:css:woocommerce-compat && npm run build:css:seo-expert && npm run build:css:admin-sitemap-status && npm run build:css:slider && npm run build:css:widgets && npm run build:css:blog-page && npm run build:css:blog-listing-hero && npm run build:css:blog-hub-block-editor && npm run build:css:editor-style && npm run build:css:slider-admin && npm run build:css:seo-home-ar",
    "build:css:main": "cleancss -o assets/css/style.min.css style.css",
    "build:css:components": "cleancss -o assets/css/components.min.css assets/css/components.css",
    "build:css:admin": "cleancss -o assets/css/admin.min.css assets/css/admin.css",
    "build:css:admin-meta-fields": "cleancss -o assets/css/admin-meta-fields.min.css assets/css/admin-meta-fields.css",
    "build:css:admin-settings": "cleancss -o assets/css/admin-settings.min.css assets/css/admin-settings.css",
    "build:css:faq-admin": "cleancss -o assets/css/faq-admin.min.css assets/css/faq-admin.css",
    "build:css:demo-content": "cleancss -o assets/css/demo-content.min.css assets/css/demo-content.css",
    "build:css:membership-plans": "cleancss -o assets/css/membership-plans.min.css assets/css/membership-plans.css",
    "build:css:membership-plans-pricing": "cleancss -o assets/css/membership-plans-pricing.min.css assets/css/membership-plans-pricing.css",
    "build:css:form-kit": "cleancss -o assets/css/form-kit.min.css assets/css/form-kit.css",
    "build:css:page-contact": "cleancss -o assets/css/page-contact.min.css assets/css/page-contact.css",
    "build:css:page-title-bar": "cleancss -o assets/css/page-title-bar.min.css assets/css/page-title-bar.css",
    "build:css:woocommerce-compat": "cleancss -o assets/css/woocommerce-compat.min.css assets/css/woocommerce-compat.css",
    "build:css:seo-expert": "cleancss -o assets/css/seo-expert.min.css assets/css/seo-expert.css",
    "build:css:admin-sitemap-status": "cleancss -o assets/css/admin-sitemap-status.min.css assets/css/admin-sitemap-status.css",
    "build:css:slider": "cleancss -o assets/css/slider.min.css assets/css/slider.css",
    "build:css:widgets": "cleancss -o assets/css/widgets-zskeleton.min.css assets/css/widgets-zskeleton.css",
    "build:css:blog-page": "cleancss -o assets/css/blog-page.min.css assets/css/blog-page.css",
    "build:css:blog-listing-hero": "cleancss -o assets/css/blog-listing-hero.min.css assets/css/blog-listing-hero.css",
    "build:css:blog-hub-block-editor": "cleancss -o assets/css/blog-hub-block-editor.min.css assets/css/blog-hub-block-editor.css",
    "build:css:editor-style": "cleancss -o assets/css/editor-style.min.css assets/css/editor-style.css",
    "build:css:slider-admin": "cleancss -o assets/css/slider-admin.min.css assets/css/slider-admin.css",
    "build:css:seo-home-ar": "cleancss -o assets/css/seo-home-ar.min.css assets/css/seo-home-ar.css",
    "build:js": "npm run build:js:main && npm run build:js:membership && npm run build:js:admin && npm run build:js:admin-settings && npm run build:js:faq-admin && npm run build:js:demo-content && npm run build:js:membership-plans && npm run build:js:membership-admin && npm run build:js:form-kit && npm run build:js:slider && npm run build:js:slider-admin && npm run build:js:admin-term-listing && npm run build:js:repeater-admin && npm run build:js:seo-expert-hero-particles && npm run build:js:admin-service-icon && npm run build:js:recaptcha && npm run build:js:stripe-handler && npm run build:js:paypal-handler",
    "build:js:main": "terser assets/js/main.js -o assets/js/main.min.js -c -m",
    "build:js:membership": "terser assets/js/membership.js -o assets/js/membership.min.js -c -m",
    "build:js:admin": "terser assets/js/admin.js -o assets/js/admin.min.js -c -m",
    "build:js:admin-settings": "terser assets/js/admin-settings.js -o assets/js/admin-settings.min.js -c -m",
    "build:js:faq-admin": "terser assets/js/faq-admin.js -o assets/js/faq-admin.min.js -c -m",
    "build:js:demo-content": "terser assets/js/demo-content.js -o assets/js/demo-content.min.js -c -m",
    "build:js:membership-plans": "terser assets/js/membership-plans.js -o assets/js/membership-plans.min.js -c -m",
    "build:js:membership-admin": "terser assets/js/membership-admin.js -o assets/js/membership-admin.min.js -c -m",
    "build:js:form-kit": "terser assets/js/form-kit.js -o assets/js/form-kit.min.js -c -m",
    "build:js:slider": "terser assets/js/slider.js -o assets/js/slider.min.js -c -m",
    "build:js:slider-admin": "terser assets/js/slider-admin.js -o assets/js/slider-admin.min.js -c -m",
    "build:js:admin-term-listing": "terser assets/js/admin-term-listing.js -o assets/js/admin-term-listing.min.js -c -m",
    "build:js:repeater-admin": "terser assets/js/repeater-admin.js -o assets/js/repeater-admin.min.js -c -m",
    "build:js:seo-expert-hero-particles": "terser assets/js/seo-expert-hero-particles.js -o assets/js/seo-expert-hero-particles.min.js -c -m",
    "build:js:admin-service-icon": "terser assets/js/admin-service-icon.js -o assets/js/admin-service-icon.min.js -c -m",
    "build:js:recaptcha": "terser assets/js/recaptcha.js -o assets/js/recaptcha.min.js -c -m",
    "build:js:stripe-handler": "terser assets/js/stripe-handler.js -o assets/js/stripe-handler.min.js -c -m",
    "build:js:paypal-handler": "terser assets/js/paypal-handler.js -o assets/js/paypal-handler.min.js -c -m",
    "watch": "npm run watch:css & npm run watch:js",
    "watch:css": "chokidar \"style.css\" \"assets/css/*.css\" -c \"npm run build:css\"",
    "watch:js": "chokidar \"assets/js/*.js\" -c \"npm run build:js\"",
    "dev": "npm run build && npm run watch",
    "clean": "rimraf assets/css/*.min.css assets/js/*.min.js"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.2",
    "terser": "^5.19.4",
    "chokidar-cli": "^3.0.0",
    "rimraf": "^5.0.5"
  },
  "keywords": [
    "wordpress",
    "theme",
    "minification",
    "build"
  ],
  "author": "ZSkeleton",
  "license": "GPL-2.0+"
}
